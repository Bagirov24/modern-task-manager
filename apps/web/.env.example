# ==============================================
# Modern Task Manager - Frontend Environment
# ==============================================
# Скопируй этот файл: cp .env.example .env
# и заполни реальными значениями

# ----------------------------------------------
# API Connection
# ----------------------------------------------
# Для Docker Compose: http://localhost:8000
# Для production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ----------------------------------------------
# Supabase (https://supabase.com)
# ----------------------------------------------
# Получи на: https://app.supabase.com -> Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----------------------------------------------
# App Settings
# ----------------------------------------------
VITE_APP_NAME=Modern Task Manager
VITE_APP_VERSION=1.0.0

# ----------------------------------------------
# Feature Flags
# ----------------------------------------------
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_DARK_MODE=true
