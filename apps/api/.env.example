# ==============================================
# Modern Task Manager - Backend Environment
# ==============================================
# Скопируй этот файл: cp .env.example .env
# и заполни реальными значениями

# ----------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------
# Для Docker Compose используй db:5432
# Для локального запуска используй localhost:5432
DATABASE_URL=postgresql://postgres:password@db:5432/taskmanager

# ----------------------------------------------
# Redis
# ----------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----------------------------------------------
# Supabase Auth (https://supabase.com)
# ----------------------------------------------
# Получи на: https://app.supabase.com -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ----------------------------------------------
# JWT Settings
# ----------------------------------------------
SECRET_KEY=change-me-to-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------
# Application Settings
# ----------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
APP_NAME=Modern Task Manager
APP_VERSION=1.0.0

# CORS - origins allowed to access the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ----------------------------------------------
# Email (SMTP)
# ----------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@taskmanager.com
EMAILS_FROM_NAME=Modern Task Manager

# ----------------------------------------------
# Optional: OpenAI (for AI features)
# ----------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key

# ----------------------------------------------
# Optional: Sentry (error monitoring)
# ----------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn

# ----------------------------------------------
# Rate Limiting
# ----------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100
